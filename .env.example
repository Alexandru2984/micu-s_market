# Django
DJANGO_SETTINGS_MODULE=Micu_market.settings_production
DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=market.example.com,www.market.example.com
DJANGO_ADMIN_URL=portal-secret-micu/

# Public origins
CSRF_TRUSTED_ORIGINS=https://market.example.com,https://www.market.example.com
CORS_ALLOWED_ORIGINS=https://market.example.com,https://www.market.example.com

# Proxy / HTTPS
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=()
CROSS_ORIGIN_RESOURCE_POLICY=same-site
CROSS_ORIGIN_OPENER_POLICY=same-origin
CONTENT_SECURITY_POLICY_REPORT_ONLY=default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://cdnjs.cloudflare.com https://fonts.gstatic.com; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
DJANGO_USE_X_FORWARDED_PROTO=True
DJANGO_TRUSTED_PROXY_CHAIN_CONFIGURED=True
ACCOUNT_CONFIRM_EMAIL_ON_GET=False

# PostgreSQL
DB_NAME=micu_market
DB_USER=micu
DB_PASS=change-me
DB_HOST=postgres
DB_PORT=5432

# Cache / rate limit
REDIS_URL=redis://redis:6379/1
RATELIMIT_USE_CACHE=default
API_READ_RATE=120/m
API_WRITE_RATE=30/m
AJAX_WRITE_RATE=120/m
REPORT_WRITE_RATE=10/h
SENSITIVE_READ_RATE=60/m
CHAT_START_RATE=30/h
AUTH_LOGIN_IP_RATE=20/5m
AUTH_LOGIN_USER_RATE=10/15m
AUTH_REGISTER_RATE=5/h
BILLING_ORDER_RATE=10/h
HOMEPAGE_CACHE_SECONDS=300
LISTING_AUTO_HIDE_REPORT_THRESHOLD=3
LISTING_VIEW_COOLDOWN_SECONDS=3600
LISTING_RISK_REVIEW_THRESHOLD=70
LISTING_RISK_TERMS=whatsapp,telegram,avans,western union,crypto,bitcoin,revolut only,livrare doar cu plata in avans
CHAT_MESSAGE_MAX_LENGTH=5000

# Static / media
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media
MEDIA_STORAGE_BACKEND=filesystem
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
PILLOW_MAX_IMAGE_PIXELS=25000000

# S3/R2 media storage, used when MEDIA_STORAGE_BACKEND=s3
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_CUSTOM_DOMAIN=
AWS_DEFAULT_ACL=
AWS_QUERYSTRING_AUTH=False
AWS_S3_CACHE_CONTROL=max-age=86400

# Offsite database backups -> Cloudflare R2 (S3-compatible), used by
# scripts/backup_postgres.sh when R2_ENABLED=1.
R2_ENABLED=0
R2_BUCKET=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BACKUP_PREFIX=postgres/
BACKUP_RETENTION_DAYS=14

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=market@example.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=Micu Market <market@example.com>
SERVER_EMAIL=server@example.com
SITE_URL=https://market.example.com

# Logging
DJANGO_LOG_TO_FILE=False
DJANGO_LOG_LEVEL=INFO
DJANGO_LOG_DIR=/var/log/micu_market

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0
