# Mediul virtual
venv/
ENV/
env/

# Fișiere de configurare mediul local
*.env
.env.*
*.bak*
!.env.example

# Local/temporary settings (not committed)
Micu_market/settings_local.py
Micu_market/settings_loadtest.py

# Seed data with PII or sensitive data
backup_seed.json
*.json.bak

# Backup-uri baza de date (contin date reale)
*.sql
*.sql.gz
*.dump
backup_*

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Django stuff:
*.log
*.pot
*.pyc
*.pyo
*.pyd
*.sqlite3
db.sqlite3

# Teste / coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Migrations (Trebuie salvate în Git pentru a menține consistența bazei de date între medii)
# NU se ignoră migrarile în Django!


# Fișiere media (imagini, upload-uri)
media/
uploads/

# Static files (dacă le generezi cu collectstatic)
staticfiles/

# IDE/editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Sistem
.DS_Store
Thumbs.db

# Gunicorn socket
gunicorn.sock

# Fișiere temporare
*.swp
*.swo
*.tmp
